# --- 核心模型接入 (Core LLM) ---
# 建议统一使用 TA_ 前缀，同时也兼容 OPENAI_API_KEY / OPENAI_BASE_URL
TA_API_KEY=
TA_BASE_URL=https://api.openai.com/v1
TA_LLM_PROVIDER=openai

# 模型名配置 (默认已提供常用值)
TA_LLM_QUICK=gpt-4o-mini
TA_LLM_DEEP=gpt-4o

# --- 安全密钥 (Security) ---
# 用于加密用户 API Key 和签发 JWT，生产环境必须设置！
# 生成方式: openssl rand -base64 32
# 首次设置时，系统会自动将已有数据从默认密钥迁移到新密钥。
# TA_APP_SECRET_KEY=

# --- 进阶可选配置 (Advanced Optional) ---
# 提示词语言 (auto / zh / en)，默认 zh
# TA_LANGUAGE=zh

# 运行日志追踪 (1 开启 / 0 关闭)，默认 1
# TA_TRACE=1

# 辩论与风险讨论轮数 (1-5)，默认 1
# TA_MAX_DEBATE=1
# TA_MAX_RISK=1

# 单个分析任务后台超时秒数，默认 1800（30 分钟）
# 如果看到“任务超时（超过 600 秒）”，请检查部署环境是否设置了 TA_JOB_TIMEOUT=600。
# TA_JOB_TIMEOUT=1800

# 东方财富个股资金流接口限频/缓存，避免高频请求触发风控
# 成功结果缓存秒数，默认 21600（6 小时）
# TA_FUND_FLOW_CACHE_TTL=21600
# 失败冷却秒数，默认 300（5 分钟），冷却内不重复请求资金流接口
# TA_FUND_FLOW_FAILURE_COOLDOWN=300
# 全局最小请求间隔秒数，默认 3
# TA_FUND_FLOW_MIN_INTERVAL=3.0

# --- 板上有黄金本地缓存扫描 (Board-Gold Scanner) ---
# 指向包含 stock_daily/、stock_daily_raw/、stock_basic/ 的本地 parquet 缓存目录。
# 可复用旧 board_has_gold 项目的 data 目录，例如 /Users/mingwen/workspace/board_has_gold/data
# TA_BOARD_GOLD_DATA_DIR=./data/board_gold
# 扫描结果 JSON 输出目录，默认 board_gold_results/，该目录不会提交 git
# TA_BOARD_GOLD_RESULTS_DIR=./board_gold_results
# 旧 board_has_gold 缓存脚本目录；默认会尝试从 TA_BOARD_GOLD_DATA_DIR 的兄弟 cache/scripts 推导
# TA_BOARD_GOLD_CACHE_SCRIPTS_DIR=./cache/board_gold/scripts
# 本地缓存更新为一键自动任务，后端会自行路由旧采集器和内置 BaoStock 数据源。
# 连续失败保护阈值，默认 12；达到阈值会停止循环并在任务日志中记录原因。
# TA_BOARD_GOLD_CACHE_CONSECUTIVE_FAIL_LIMIT=12
# 后台扫描线程数，默认 1，建议保持低并发以减少本地 IO 抖动
# TA_BOARD_GOLD_SCAN_WORKERS=1

# --- VLM 截图识别 (Vision Language Model) ---
# 用于持仓截图识别，默认使用智谱 glm-4.6v-flash（免费）
# TA_VLM_API_KEY=你的智谱API Key
# TA_VLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# TA_VLM_MODEL=glm-4.6v-flash

# --- 邮件服务 (Email/SMTP) ---
# 仅在需要开启邮箱验证码登录时配置
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=465
# MAIL_USER=你的邮箱
# MAIL_PASS=你的授权码
# MAIL_FROM=发件人名称
# MAIL_SSL=1

# 兼容说明: 系统自动识别 TA_ 前缀变量。
# 若需修改默认行为，取消上述注释并填值即可。
